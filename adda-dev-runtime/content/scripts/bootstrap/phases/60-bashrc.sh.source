# ======================================================================
# 60-bashrc.sh — Write ~/.bashrc with PS1 and propagated env vars
#
# Sourced by: entrypoint.sh (after all entrypoint.d hooks and the
#   repo-level .adda-init.sh hook)
# Sourcing context: requires section/success helpers defined in
#   00-helpers.sh; requires HTTP_PROXY/HTTPS_PROXY/http_proxy/
#   https_proxy/NO_PROXY/no_proxy exported by 40-proxy.sh; requires
#   GH_REPO exported by 50-github.sh; must run after all hooks so the
#   file reflects the entrypoint's final environment state, including
#   anything hooks may export.
# Exports nothing; writes ~/.bashrc (intentional overwrite — ephemeral
#   container).
# ======================================================================

# ----------------------------------------------------------------------
# Write ~/.bashrc with PS1 and propagated environment variables.
#
# Placed here — after start_proxy_bridge (which exports the proxy vars),
# after export GH_REPO, and after hooks — so the file reflects the
# entrypoint's final environment, including anything hooks may export.
# This is an ephemeral container; overwriting .bashrc is intentional.
# ----------------------------------------------------------------------
section "Initializing shell config in ~/.bashrc."

write_bashrc() {
    cat > "${HOME}/.bashrc" <<EOF
# ADDA Dev container shell config.
# Generated by entrypoint.sh.

_adda_prompt_issue() {
    local id
    id="\$(/usr/local/libexec/adda-dev-runtime/bin/current-issue get id 2>/dev/null)"
    [[ -n "\$id" ]] && printf ' #%s' "\$id"
}

export PS1='\\[\\033[1;36m\\][adda-dev ${GITHUB_REPO}\$(_adda_prompt_issue)\\]\\[\\033[0m\\] \\w\\$ '

export HTTP_PROXY='${HTTP_PROXY}'
export HTTPS_PROXY='${HTTPS_PROXY}'
export http_proxy='${http_proxy}'
export https_proxy='${https_proxy}'
export NO_PROXY='${NO_PROXY}'
export no_proxy='${no_proxy}'
export GH_REPO='${GH_REPO}'
EOF
}
write_bashrc
success "Shell config written to ~/.bashrc."
