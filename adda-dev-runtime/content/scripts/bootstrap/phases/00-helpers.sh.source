# ======================================================================
# 00-helpers.sh — Output and validation helper functions
#
# Sourced by: entrypoint.sh (before any other phase)
# Sourcing context: runs in the entrypoint shell; defines functions
#   available to all subsequent phases and entrypoint.d hooks.
# Exports nothing; all definitions land in the sourcing shell's namespace.
# ======================================================================

# ----------------------------------------------------------------------
# Output helpers
# ----------------------------------------------------------------------

# _in_hook — returns true when called from within the entrypoint hook loop.
# The entrypoint sets _HOOKS_BOOTSTRAP_MODE=1 (not exported) before sourcing
# hooks and unsets it afterwards; subshells and subprocess do not inherit it.
_in_hook() { [[ -n "${_HOOKS_BOOTSTRAP_MODE:-}" ]]; }

# hook_banner — prints the hook filename as a section header at 2-space indent.
# Called by the entrypoint hook loop, not by hook authors directly.
# Does not check _in_hook(); always renders at the fixed 2-space level.
hook_banner() { printf '\n  \033[1;32m%s\033[0m\n' "$*"; }

section() {
    if _in_hook; then
        printf '    \033[0;37m->\033[0m %s\n' "$*"
    else
        printf '\n\033[1;32m==> %s\033[0m\n' "$*"
    fi
}

die() {
    if _in_hook; then
        printf '      \033[1;31mError:\033[0m %s\n' "$*" >&2
    else
        printf '\033[1;31mError:\033[0m %s\n' "$*" >&2
    fi
    exit 1
}

warning() {
    if _in_hook; then
        printf '      \033[1;33mWarning:\033[0m %s\n' "$*" >&2
    else
        printf '\033[1;33mWarning:\033[0m %s\n' "$*" >&2
    fi
}

success() {
    if _in_hook; then
        printf '      \033[1;32m✓\033[0m %s\n' "$*"
    else
        printf '\033[1;32m✓\033[0m %s\n' "$*"
    fi
}

# info — print a plain informational line.
# Use instead of bare echo in hooks and bootstrap scripts.
# In hook mode, indents to 6 spaces to align with success/warning/die.
info() {
    if _in_hook; then
        printf '      %s\n' "$*"
    else
        printf '%s\n' "$*"
    fi
}

# ----------------------------------------------------------------------
# Validation helpers
# ----------------------------------------------------------------------
require_env() {
    local var="$1"
    local show_value="${2:-false}"
    if [[ -z "${!var:-}" ]]; then
        die "required environment variable '${var}' is not set; check the launcher."
    fi
    local text="$var"
    if [[ "$show_value" == "true" ]]; then
        text="${text}=${!var}"
    fi
    success "$text"
}

require_tool() {
    local tool="$1"
    if ! command -v "$tool" >/dev/null 2>&1; then
        die "tool '${tool}' not found in PATH. Container image does not match entrypoint.sh prerequisites; cannot proceed."
    fi
    success "$tool"
}

# ----------------------------------------------------------------------
# Shell tools helpers
# ----------------------------------------------------------------------

_ANNOUNCED_SHELL_TOOLS=""
_SHELL_TOOLS_SEALED=""

# announce_shell_tool name cmd desc
# Registers a shell tool entry in JSONL format.
# entrypoint.d hooks may also call this to extend the list before Tier 1 writes the registry.
# Fails with a non-zero exit if called after hook 95 has sealed the registry.
announce_shell_tool() {
    if [[ -n "${_SHELL_TOOLS_SEALED}" ]]; then
        die "announce_shell_tool: registry is sealed (hook 95 has run)"
    fi
    local name="$1" cmd="$2" desc="$3"
    local entry
    entry=$(jq -cn --arg n "$name" --arg c "$cmd" --arg d "$desc" \
        '{"name":$n,"cmd":$c,"desc":$d}')
    _ANNOUNCED_SHELL_TOOLS="${_ANNOUNCED_SHELL_TOOLS}${entry}"$'\n'
}

# list_shell_tools — prints accumulated JSONL to stdout, one object per line.
# Fails with a non-zero exit if called before hook 95 has sealed the registry.
list_shell_tools() {
    if [[ -z "${_SHELL_TOOLS_SEALED}" ]]; then
        die "list_shell_tools: registry is not yet sealed (call after hook 95)"
    fi
    printf '%s' "${_ANNOUNCED_SHELL_TOOLS}"
}
