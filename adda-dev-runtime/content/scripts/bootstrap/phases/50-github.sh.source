# ======================================================================
# 50-github.sh — GitHub authentication, user details, clone, and branch
#
# Sourced by: entrypoint.sh (after 40-proxy.sh)
# Sourcing context: requires section/die/success helpers defined in
#   00-helpers.sh; requires GITHUB_TOKEN_, GITHUB_OWNER, GITHUB_REPO
#   validated in 10-validate-env.sh; proxy must be up (40-proxy.sh)
#   for gh and git network calls to succeed. ISSUE_ID is consumed and
#   unset here after seeding current-issue state; it must not leak into
#   the interactive session.
# Exports: GH_REPO, GH_USER_ID, GH_USERNAME
# ======================================================================

# ----------------------------------------------------------------------
# Configure GitHub authentication via gh
# This installs gh's git credential helper as a side effect, so both
# `gh` and `git` work against github.com without further setup.
#
# GITHUB_TOKEN_ (with trailing underscore) is the launcher → container
# contract; gh does not recognize it, so we can pipe it directly to
# `gh auth login` without first unsetting a reserved env var. After
# auth, the token lives in gh's credential helper config, so we drop
# GITHUB_TOKEN_ from the environment.
# ----------------------------------------------------------------------
section "Configuring GitHub authentication"

echo "$GITHUB_TOKEN_" | gh auth login --with-token --hostname github.com
unset GITHUB_TOKEN_
gh auth setup-git
gh auth status

# Set gh's reserved GH_REPO so subsequent gh calls (entrypoint's own
# and the user's interactive ones) target the project repo by default.
export GH_REPO="${GITHUB_OWNER}/${GITHUB_REPO}"

success "GitHub authentication initialized."

# ----------------------------------------------------------------------
# Fetch GitHub user details
# Populate GH_USER_ID and GH_USERNAME so downstream hooks (e.g. the
# proto-adda Tier 2 hook) can use them without making their own API calls.
# ----------------------------------------------------------------------
section "Fetching GitHub user details"

GH_USER_ID="$(gh api user --jq .id)"
GH_USERNAME="$(gh api user --jq .login)"
success "GitHub user: ${GH_USERNAME} (id=${GH_USER_ID})."

# ----------------------------------------------------------------------
# Clone the project repository
# ----------------------------------------------------------------------
section "Cloning ${GH_REPO} into /workspace"

git clone "https://github.com/${GH_REPO}.git" /workspace
cd /workspace
success "Repository cloned."

# ----------------------------------------------------------------------
# Switch to the issue branch
# current-issue switch resolves the branch, checks it out, and writes
# the issue state to /run/.adda-current-issue. --skip-repo-init defers
# the repo-level init hook to the entrypoint's dedicated REPO INIT step.
# ----------------------------------------------------------------------
section "Switching to issue branch"

if [[ -z "${ISSUE_ID:-}" ]]; then
    success "No ISSUE_ID; staying on main."
else
    if ! _switch_out="$(/usr/local/libexec/adda-dev-runtime/bin/current-issue switch "${ISSUE_ID}" --skip-repo-init)"; then
        _switch_error="$(printf '%s' "${_switch_out}" | jq -r '.error // empty' 2>/dev/null || true)"
        die "Issue #${ISSUE_ID}: switch failed${_switch_error:+: ${_switch_error}}"
    fi
    _switch_branch="$(printf '%s' "${_switch_out}" | jq -r '.details.branch')"
    _switch_resolution="$(printf '%s' "${_switch_out}" | jq -r '.details.resolution')"
    _switch_pr="$(printf '%s' "${_switch_out}" | jq -r '.issue.pr')"
    if [[ "${_switch_resolution}" == "main" ]]; then
        success "Issue #${ISSUE_ID}: no linked branch yet; staying on main."
        echo "Branch creation is the SDLC's spec phase responsibility."
    elif [[ -n "${_switch_pr}" ]]; then
        echo "Issue #${ISSUE_ID}: resolved via open PR #${_switch_pr} (branch: ${_switch_branch})."
        success "Checked out branch ${_switch_branch} for Issue #${ISSUE_ID}."
    else
        echo "Issue #${ISSUE_ID}: one linked branch (${_switch_branch}); checking out."
        success "Checked out branch ${_switch_branch} for Issue #${ISSUE_ID}."
    fi
    unset ISSUE_ID
fi
