#!/bin/bash
# ======================================================================
# entrypoint.sh — Tier 1 base bootstrap sequencer
#
# Runs as the container's ENTRYPOINT. Receives configuration via env vars
# from the launcher (adda-dev.sh on the host):
#
#   GITHUB_OWNER, GITHUB_REPO        Project identity; GH_REPO is derived
#                                    as OWNER/REPO inside the container.
#   GITHUB_TOKEN_                    GitHub token. Trailing underscore is
#                                    intentional: it avoids gh's reserved
#                                    GH_TOKEN/GITHUB_TOKEN names so
#                                    `gh auth login` works without an
#                                    unset dance before login.
#   TZ                               Host timezone.
#   ISSUE_ID                         Optional GitHub Issue number.
#   ADDA_DEV_PROXY_SOCKET          Bind-mounted proxy socket path.
#   ADDA_DEV_PROXY_PORT            Local TCP port for the socat proxy
#                                    bridge.
#   ADDA_DEV_RUNTIME_IMAGE           Full image reference (registry/name:tag).
#                                    Injected by the launcher at run time.
#   ADDA_DEV_RUNTIME_IMAGE_COMMIT_SHA  Git SHA baked at build time by CI; empty
#                                    for local builds.
#
# Organized as a thin sequencer that sources phase files from the
# bootstrap/phases/ subdirectory. Each phase file is a focused,
# single-concern script:
#
#   00-helpers.sh                — output and validation helper functions
#   10-validate-env.sh           — env vars, tools, /workspace check
#   20-harden-checks.sh          — network and capability checks
#   30-harden-checks-filesystem.sh — filesystem hardening checks
#   40-proxy.sh                  — socat proxy bridge
#   50-github.sh                 — GitHub auth, user, clone, branch
#   60-bashrc.sh                 — write ~/.bashrc (after all hooks)
#
# Bootstrap traps, the entrypoint.d hooks loop, the repo-init hook,
# the bootstrap summary, and CMD exec remain here in the sequencer.
#
# ======================================================================

set -euo pipefail
_bootstrap_start=$SECONDS

_PHASES_DIR="$(dirname "$(realpath "${BASH_SOURCE[0]}")")/phases"

# ----------------------------------------------------------------------
# Phase 00: helpers — must be first; all phases depend on these
# ----------------------------------------------------------------------
# shellcheck disable=SC1091
# Why: phases/ files are co-located scripts discovered at runtime via
# _PHASES_DIR; the source path is intentionally dynamic.
source "${_PHASES_DIR}/00-helpers.sh"

# ======================================================================
# BASE — generic dev environment bootstrap
# ======================================================================
section "Welcome to ephemeral ADDA Dev Runtime"

# ----------------------------------------------------------------------
# Bootstrap-failure EXIT trap — installed before validate-env so any
# early failure pauses the container for autopsy.
# ----------------------------------------------------------------------
# shellcheck disable=SC2317
# Why: function body runs via `trap bootstrap_failure EXIT`; shellcheck
# does not follow trap-bound execution paths.
bootstrap_failure() {
    printf '\n\033[1;31m==> %s\033[0m\n' "Entrypoint bootstrap failed, ADDA Dev Runtime cannot proceed."
    read -r -s -n 1 -p $'\nPress any key to exit the container...' _
}
trap bootstrap_failure EXIT

# shellcheck disable=SC1091
# Why: phases/ files are co-located scripts discovered at runtime via
# _PHASES_DIR; the source path is intentionally dynamic.
source "${_PHASES_DIR}/10-validate-env.sh"
# shellcheck disable=SC1091
# Why: phases/ files are co-located scripts discovered at runtime via
# _PHASES_DIR; the source path is intentionally dynamic.
source "${_PHASES_DIR}/20-harden-checks.sh"
# shellcheck disable=SC1091
# Why: phases/ files are co-located scripts discovered at runtime via
# _PHASES_DIR; the source path is intentionally dynamic.
source "${_PHASES_DIR}/30-harden-checks-filesystem.sh"

# ----------------------------------------------------------------------
# Bootstrap-complete marker — EXIT trap (failure safety net)
#
# Installed after verify_filesystem_hardening confirms /run is a writable
# tmpfs owned by the runtime user. From here on, any premature exit (die,
# set -e failure, signal) still touches the marker so the parallel
# "adda-dev shell" window opens for autopsy.
#
# The initial trap covers only the marker. It is replaced below (after
# git_trail is defined) with a combined trap: marker first so the shell
# window unblocks before git_trail's blocking read prompt.
# ----------------------------------------------------------------------
# shellcheck disable=SC2317
# Why: function body runs via `trap mark_bootstrap_complete EXIT`; shellcheck
# does not follow trap-bound execution paths.
mark_bootstrap_complete() {
    touch /run/.adda_bootstrap_complete 2>/dev/null || true
}
trap mark_bootstrap_complete EXIT

# shellcheck disable=SC1091
# Why: phases/ files are co-located scripts discovered at runtime via
# _PHASES_DIR; the source path is intentionally dynamic.
source "${_PHASES_DIR}/40-proxy.sh"
# shellcheck disable=SC1091
# Why: phases/ files are co-located scripts discovered at runtime via
# _PHASES_DIR; the source path is intentionally dynamic.
source "${_PHASES_DIR}/50-github.sh"

# ======================================================================
# Entrypoint hooks — sourced by Tier 1 entrypoint after BASE init and
# before CMD handoff. Tier 1 ships nothing here; proto/project layers
# drop *.sh files via Dockerfile COPY. Sourced (not subprocess) so
# hooks can mutate env for downstream tooling and CMD.
# ======================================================================

if [[ -d /usr/local/libexec/adda-dev-runtime/bootstrap/entrypoint.d ]]; then
    shopt -s nullglob
    hooks=(/usr/local/libexec/adda-dev-runtime/bootstrap/entrypoint.d/*.sh)
    shopt -u nullglob
    if (( ${#hooks[@]} > 0 )); then
        section "Running bootstrap hooks"
        _HOOKS_BOOTSTRAP_MODE=1
        for hook in "${hooks[@]}"; do
            hook_banner "$(basename "${hook}")"
            # shellcheck disable=SC1090
            # Why: hooks are discovered at runtime via glob over
            # /usr/local/libexec/adda-dev-runtime/bootstrap/entrypoint.d/*.sh; the source
            # path is intentionally dynamic.
            source "${hook}"
        done
        unset _HOOKS_BOOTSTRAP_MODE
        printf '\n'
        success "Bootstrap hooks complete."
    fi
fi

# ======================================================================
# REPO INIT — optional repo-level init hook
# Sourced after image hooks so it has access to the full bootstrapped
# environment: GitHub auth, proxy, git config, and any exports from
# entrypoint.d hooks. Non-existence is not an error.
# ======================================================================
section "Running repo-level init hook (.adda-init.sh)"

if [[ -f /workspace/.adda-init.sh ]]; then
    bash /workspace/.adda-init.sh
    success "Repo-level init hook complete."
else
    info "No .adda-init.sh found in /workspace; skipping."
fi

# ======================================================================
# COMMON — handoff to CMD
# ======================================================================

# Phase 60: write ~/.bashrc — must come after all hooks so it captures
# the final environment state, including anything hooks may export.
# shellcheck disable=SC1091
# Why: phases/ files are co-located scripts discovered at runtime via
# _PHASES_DIR; the source path is intentionally dynamic.
source "${_PHASES_DIR}/60-bashrc.sh"

# Touch the marker explicitly so the "adda-dev shell" tmux window opens
# promptly without waiting for CMD or the EXIT trap.
touch /run/.adda_bootstrap_complete

section "Bootstrap complete ($(( SECONDS - _bootstrap_start ))s)"

_CI_ID="$(/usr/local/libexec/adda-dev-runtime/bin/current-issue get id 2>/dev/null)"
if [[ -n "${_CI_ID}" ]]; then
    _CI_TITLE="$(/usr/local/libexec/adda-dev-runtime/bin/current-issue get title 2>/dev/null || echo '(unable to fetch)')"
    info "Issue: #${_CI_ID} — ${_CI_TITLE}."
fi
unset _CI_ID _CI_TITLE
info "Branch: $(git rev-parse --abbrev-ref HEAD)"
COMMITS_AHEAD="$(git rev-list --count origin/main..HEAD 2>/dev/null || echo 0)"
if [[ "${COMMITS_AHEAD}" -gt 0 ]]; then
    info "Commits ahead of origin/main: ${COMMITS_AHEAD}."
fi
printf '\n'

# ----------------------------------------------------------------------
# Final steps:
# - define exit trap to report git status trail
# - exec CMD (claude by default) with args passed from the launcher
# - drop into interactive bash when CMD exits
# ----------------------------------------------------------------------

# shellcheck disable=SC2317,SC1083
# Why: SC2317 — function body runs via `trap 'mark_bootstrap_complete; git_trail' EXIT`.
# SC1083 — `@{u}` is git revision syntax (upstream tracking branch),
# not shell brace expansion.
git_trail() {
    section "Git state on exit"
    git -C /workspace status || true
    if git -C /workspace rev-parse @{u} >/dev/null 2>&1; then
        git --no-pager -C /workspace log --oneline @{u}..HEAD
    else
        info "(branch not yet pushed to remote)"
    fi
    read -r -s -n 1 -p $'\nPress any key to exit the container...' _
}

# Replace the early marker-only trap with the combined trap.
# Order: marker first (so the shell window unblocks before git_trail's
# blocking read prompt), then git_trail.
trap 'mark_bootstrap_complete; git_trail' EXIT

# Run CMD (/bin/bash by default, or any override). Bootstrap stays strict, but
# command failures after bootstrap should leave the user in an interactive
# shell for inspection instead of terminating the container immediately.
cmd_status=0
"$@" || cmd_status=$?

if [[ "$cmd_status" -ne 0 ]]; then
    warning "Command exited with status ${cmd_status}; dropping into interactive shell."
else
    info "Command exited successfully; dropping into interactive shell."
fi

bash
exit "$cmd_status"
