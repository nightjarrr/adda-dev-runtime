# ======================================================================
# 95-write-shell-tools-registry.sh — Tier 1 gate: seals and writes the
#   shell tools registry.
#
# Sourced by: entrypoint.sh (as an entrypoint.d hook, after all 10–79
#   extension hooks have had the opportunity to call announce_shell_tool).
# Sourcing context: runs in the entrypoint shell; all helper functions
#   from 00-helpers.sh are available.
#
# Effect: sets _SHELL_TOOLS_SEALED="1" to activate bidirectional guards,
#   then writes the accumulated JSONL registry to
#   /run/adda/.adda-shell-tools.jsonl. Hooks numbered 96+ may read the
#   registry but must not call announce_shell_tool.
# ======================================================================

section "Writing shell tool registry"

_SHELL_TOOLS_SEALED="1"

if [[ -z "${_ANNOUNCED_SHELL_TOOLS}" ]]; then
    warning "_ANNOUNCED_SHELL_TOOLS is empty — shell tool registry not written."
else
    list_shell_tools > /run/adda/.adda-shell-tools.jsonl
    success "Shell tool registry written to /run/adda/.adda-shell-tools.jsonl."
fi
