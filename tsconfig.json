{
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "types": ["bun"],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@adda/lib": ["adda-dev-runtime/src/lib"],
      "@adda/lib/*": ["adda-dev-runtime/src/lib/*"]
    }
  }
}
