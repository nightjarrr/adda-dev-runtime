{
  "autoMemoryDirectory": "/workspace/.claude/memory",
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true
  },
  "permissions": {
    "additionalDirectories": ["/tmp"],
    "allow": [
      "Bash(git *)",
      "Bash(gh issue *)",
      "Bash(gh label *)",
      "Bash(gh pr create *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr status *)",
      "Bash(gh pr checks *)",
      "Bash(gh release list *)",
      "Bash(gh release view *)",
      "Bash(printenv *)",
      "Bash(/usr/local/libexec/adda-dev-runtime/bin/*)",
      "Bash(bun *)",
      "Bash(tsc *)",
      "Bash(oxlint *)",
      "Bash(oxfmt *)",
      "Bash(jq *)",
      "Bash(gh run *)",
      "Bash(gh pr comment *)",
      "Bash(gh api repos/*/pulls/*)",
      "Skill(new-issue)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:docs.astral.sh)",
      "WebFetch(domain:docs.python.org)",
      "WebSearch",
      "Write(~/.issue)",
      "Write(/tmp/*)"
    ],
    "deny": [
      "Bash(gh pr merge *)",
      "Bash(git push --force *)",
      "Bash(git push * --force *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git push * --force-with-lease *)",
      "Bash(gh secret *)",
      "Bash(gh auth *)",
      "Bash(gh repo delete *)",
      "Bash(gh run delete *)"
    ]
  }
}
