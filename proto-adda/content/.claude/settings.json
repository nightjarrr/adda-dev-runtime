{
  "autoMemoryDirectory": "/workspace/.claude/memory",
  "env": {
    "ADDA_STATUSLINE_CTX_RED_THRESHOLD": "80"
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true
  },
  "permissions": {
    "additionalDirectories": ["/tmp", "/run/adda"],
    "allow": [
      "Bash(git *)",
      "Bash(gh issue *)",
      "Bash(gh label *)",
      "Bash(gh pr create *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr status *)",
      "Bash(gh pr checks *)",
      "Bash(gh release list *)",
      "Bash(gh release view *)",
      "Bash(/usr/local/libexec/adda-dev-runtime/bin/*)",
      "Bash(bun *)",
      "Bash(rg *)",
      "Bash(fdfind *)",
      "Bash(jq *)",
      "Bash(gh run *)",
      "Bash(gh pr comment *)",
      "Bash(gh api repos/*/pulls/*)",
      "Bash(gh search *)",
      "Skill(new-issue)",
      "Skill(ci-gate)",
      "Skill(backlog-management)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebSearch",
      "Write(/tmp/*)"
    ],
    "deny": [
      "Bash(gh pr merge *)",
      "Bash(git push --force *)",
      "Bash(git push * --force *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git push * --force-with-lease *)",
      "Bash(gh secret *)",
      "Bash(gh auth *)",
      "Bash(gh repo delete *)",
      "Bash(gh run delete *)",
      "Bash(gh release create *)"
    ]
  },
  "spinnerTipsEnabled": false,
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh",
    "refreshInterval": 5
  }
}
